# Copy this file to .env and fill in your Firebase project values
# Firebase Console → Project Settings → Your apps → Web app → firebaseConfig

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Airtable — Escalation board integration (server-side only, no VITE_ prefix)
# Generate token at: airtable.com/create/tokens
# Scopes needed: data.records:read  data.records:write
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_TABLE_NAME=Escalations
